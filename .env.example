# Copy to .env and fill in. Used by docker-compose.

# Required: OpenAI key for LLM + embeddings.
OPENAI_API_KEY=sk-...

# Postgres credentials (used by both the `postgres` and `app` services).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_maker

# Host port to expose the app on.
APP_PORT=8080

# Server log level.
RUST_LOG=info
